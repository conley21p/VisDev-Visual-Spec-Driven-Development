{
  "name": "visdev",
  "displayName": "VisDev",
  "description": "A GUI-based IDE for Visual Spec Driven Development",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sdd-ide.openBlueprint",
        "title": "VisDev: Open Blueprint"
      },
      {
        "command": "sdd-ide.setApiKey",
        "title": "VisDev: Set API Key"
      },
      {
        "command": "sdd-ide.showApiKey",
        "title": "VisDev: Show API Key"
      },
      {
        "command": "sdd-ide.renameModel",
        "title": "VisDev: Rename LLM Model"
      },
      {
        "command": "sdd-ide.setDefaultModel",
        "title": "VisDev: Set Default LLM Model"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sdd-ide-sidebar",
          "title": "VisDev IDE",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "sdd-ide-sidebar": [
        {
          "type": "webview",
          "id": "sdd-ide.chatView",
          "name": "Vibe Chat"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "test": "vscode-test",
    "build:webview": "cd webview-ui && npm run build"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "20.x",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "@typescript-eslint/parser": "^7.7.1",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.3.9",
    "eslint": "^8.57.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.5",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "yaml": "^2.8.3"
  }
}
